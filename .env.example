# Copy to .env and edit for SQL Server
# DB_BACKEND=sqlite
# DATABASE_PATH=agro_users.db

DB_BACKEND=mssql
MSSQL_SERVER=localhost\SQLEXPRESS
MSSQL_DATABASE=AgroVision
# Windows login (no sa password) — use this if SSMS connects with Windows Authentication:
MSSQL_TRUSTED_CONNECTION=yes
# SQL login (sa) — only if you use a username/password instead:
# MSSQL_USER=sa
# MSSQL_PASSWORD=YourStrongPassword123!
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
MSSQL_TRUST_SERVER_CERTIFICATE=yes

SECRET_KEY=change-me-in-production
FLASK_ENV=development
PORT=5000
